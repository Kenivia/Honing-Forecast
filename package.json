{
    "name": "honing-forecast",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "npm run wasm && vite",
        "wasm": "wasm-pack build crates/wasm --release --target web",
        "test": "cargo test -p hf-core --profile release --no-default-features --features active_version,run_tests -- --no-capture",
        "no-test-build": "npm run wasm && vite build",
        "build": "npm run test && npm run no-test-build && cargo +nightly udeps",
        "no-check-deploy": "git push origin main:Production --force-with-lease",
        "deploy": "pwsh -File ./scripts/pre_deploy_check.ps1 && npm run no-check-deploy",
        "optimizer-test": "pwsh -File ./scripts/optimizer_test.ps1",
        "optimizer-visualizer": "python -m pip -q install -r  ./scripts/optimizer_visualizer/requirements.txt && python ./scripts/optimizer_visualizer/app.py"
    },
    "dependencies": {
        "vue": "^3.5.29"
    },
    "devDependencies": {
        "@eslint/js": "^9.33.0",
        "@testing-library/jest-dom": "^6.8.0",
        "@types/node": "^24.3.0",
        "@typescript-eslint/eslint-plugin": "^8.42.0",
        "@typescript-eslint/parser": "^8.42.0",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vue/compiler-sfc": "^3.5.23",
        "eslint": "^9.34.0",
        "gh-pages": "^6.3.0",
        "globals": "^16.3.0",
        "jsdom": "^27.0.0",
        "typescript": "^5.9.2",
        "vite": "^6.3.6",
        "vitest": "^3.2.4"
    }
}