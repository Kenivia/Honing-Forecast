{
  "compilerOptions": {
    "target": "es2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2024"],
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": false,
    "outDir": "dist",
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@/*": ["./frontend/*"],
      "*": ["./frontend/*"]
    },
    "types": ["vite/client", "@types/dom-mediacapture-transform"]
  },
  "include": ["frontend/**/*", "crates/wasm/pkg/**/*", "vite.config.ts"],
  "exclude": ["node_modules", "dist", "junkyard"]
}
